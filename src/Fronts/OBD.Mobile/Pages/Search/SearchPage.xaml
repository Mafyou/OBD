<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:OBD.Mobile.ViewModels"
             xmlns:models="clr-namespace:OBD.Mobile.Lib.Models;assembly=OBD.Mobile.Lib"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="OBD.Mobile.Pages.Search.SearchPage"
             x:DataType="vm:SearchViewModel"
             Title="Recherche"
             BackgroundColor="{StaticResource BackgroundPrimary}">

    <ContentPage.Resources>
        <toolkit:InvertedBoolConverter x:Key="InvertedBool" />
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*">

        <SearchBar x:Name="MainSearchBar"
                   Grid.Row="0"
                   Text="{Binding SearchQuery}"
                   Placeholder="Rechercher contacts, notes, secteurs..."
                   Margin="16,8" />

        <Grid Grid.Row="1">

            <Label Text="Saisissez un terme pour rechercher"
                   TextColor="{StaticResource TextSecondary}"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"
                   IsVisible="{Binding HasSearched, Converter={StaticResource InvertedBool}}" />

            <Label Text="Aucun résultat"
                   TextColor="{StaticResource TextSecondary}"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"
                   IsVisible="{Binding HasNoResults}" />

            <CollectionView ItemsSource="{Binding Results}"
                            IsVisible="{Binding HasResults}"
                            Margin="0,4">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:SearchResult">
                        <Border Margin="16,4"
                                BackgroundColor="{StaticResource BackgroundSurface}"
                                StrokeThickness="0"
                                Padding="16,12">
                            <Border.StrokeShape><RoundRectangle CornerRadius="12" /></Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:SearchViewModel}}, Path=OpenResultCommand}"
                                    CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>
                            <VerticalStackLayout Spacing="2">
                                <Label Text="{Binding Title}"
                                       FontFamily="GeistSemiBold"
                                       FontSize="15"
                                       TextColor="{StaticResource TextPrimary}" />
                                <Label Text="{Binding Subtitle}"
                                       FontSize="13"
                                       TextColor="{StaticResource TextSecondary}" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </Grid>

    </Grid>

</ContentPage>
