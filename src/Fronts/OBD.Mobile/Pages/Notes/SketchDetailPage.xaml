<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:OBD.Mobile.ViewModels"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="OBD.Mobile.Pages.Notes.SketchDetailsPage"
             x:DataType="vm:SketchDetailsViewModel"
             Title="{Binding PageTitle}"
             Shell.TabBarIsVisible="False"
             BackgroundColor="{StaticResource BackgroundPrimary}">

    <ContentPage.Resources>
        <toolkit:InvertedBoolConverter x:Key="InvertedBool" />
    </ContentPage.Resources>

    <Grid>

        <!-- View mode: full-page image + title + Modifier button -->
        <Grid IsVisible="{Binding IsViewMode}" RowDefinitions="Auto,*,Auto">
            <Border Grid.Row="0"
                    BackgroundColor="{StaticResource BackgroundSurface}"
                    StrokeThickness="0" Padding="16,12" Margin="16,12,16,0">
                <Border.StrokeShape><RoundRectangle CornerRadius="12" /></Border.StrokeShape>
                <Label Text="{Binding Note.Title}"
                       TextColor="{StaticResource TextPrimary}"
                       FontFamily="GeistSemiBold"
                       FontSize="16" />
            </Border>
            <Image Grid.Row="1"
                   Source="{Binding CurrentImage}"
                   Aspect="AspectFit"
                   Margin="0" />
            <Button Grid.Row="2"
                    Text="Modifier"
                    Command="{Binding EditCommand}"
                    BackgroundColor="{StaticResource AccentPrimary}"
                    TextColor="{StaticResource BackgroundPrimary}"
                    CornerRadius="28"
                    WidthRequest="120"
                    HeightRequest="48"
                    HorizontalOptions="End"
                    Margin="0,0,24,32" />
        </Grid>

        <!-- Edit mode: title entry + canvas + action buttons -->
        <Grid IsVisible="{Binding IsEditMode}" RowDefinitions="Auto,*,Auto">

            <!-- Title entry -->
            <Border Grid.Row="0"
                    BackgroundColor="{StaticResource BackgroundSurface}"
                    StrokeThickness="0" Padding="4,0" Margin="16,12,16,0">
                <Border.StrokeShape><RoundRectangle CornerRadius="12" /></Border.StrokeShape>
                <Entry Placeholder="Nom du croquis (optionnel)"

                       Text="{Binding Note.Title}"
                       TextColor="{StaticResource TextPrimary}"
                       PlaceholderColor="{StaticResource TextSecondary}"
                       BackgroundColor="Transparent" />
            </Border>

            <!-- Drawing area -->
            <Grid Grid.Row="1" x:Name="SketchEditorSurface">
                <Image Source="{Binding CurrentImage}"
                       Opacity="1"
                       Aspect="AspectFit"
                       IsVisible="{Binding IsNew, Converter={StaticResource InvertedBool}}" />
                <toolkit:DrawingView x:Name="DrawingCanvas"
                                     BackgroundColor="Transparent"
                                     LineColor="{StaticResource TextPrimary}"
                                     LineWidth="3"
                                     IsMultiLineModeEnabled="True" />
            </Grid>

            <!-- Buttons -->
            <VerticalStackLayout Grid.Row="2" Spacing="8" Padding="16,0,16,16">
                <Button Text="Tout effacer"
                        Clicked="OnClearClicked"
                        BackgroundColor="{StaticResource BackgroundSurface}"
                        TextColor="{StaticResource TextPrimary}"
                        CornerRadius="12" />
                <Button Text="Sauvegarder"
                        Clicked="OnSaveClicked"
                        BackgroundColor="{StaticResource AccentPrimary}"
                        TextColor="{StaticResource BackgroundPrimary}"
                        CornerRadius="12" />
                <Button Text="Supprimer"
                        Command="{Binding DeleteCommand}"
                        IsVisible="{Binding IsNew, Converter={StaticResource InvertedBool}}"
                        BackgroundColor="Transparent"
                        TextColor="#EF4444"
                        CornerRadius="12" />
            </VerticalStackLayout>

        </Grid>

    </Grid>

</ContentPage>
