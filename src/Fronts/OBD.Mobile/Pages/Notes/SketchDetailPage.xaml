<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:OBD.Mobile.ViewModels"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="OBD.Mobile.Pages.Notes.SketchDetailsPage"
             x:DataType="vm:SketchDetailsViewModel"
             Title="{Binding PageTitle}"
             Shell.TabBarIsVisible="False"
             BackgroundColor="{StaticResource BackgroundPrimary}">

    <ContentPage.Resources>
        <toolkit:InvertedBoolConverter x:Key="InvertedBool" />
    </ContentPage.Resources>

    <Grid>

        <!-- View mode: full-page image + title + Modifier button -->
        <Grid IsVisible="{Binding IsViewMode}" RowDefinitions="Auto,*,Auto">
            <Border Grid.Row="0"
                    BackgroundColor="{StaticResource BackgroundSurface}"
                    StrokeThickness="0" Padding="16,12" Margin="16,12,16,0">
                <Border.StrokeShape><RoundRectangle CornerRadius="12" /></Border.StrokeShape>
                <Label Text="{Binding Note.Title}"
                       TextColor="{StaticResource TextPrimary}"
                       FontFamily="GeistSemiBold"
                       FontSize="16" />
            </Border>
            <Image Grid.Row="1"
                   Source="{Binding CurrentImage}"
                   Aspect="AspectFit"
                   Margin="0" />
            <Button Grid.Row="2"
                    Text="Modifier"
                    Command="{Binding EditCommand}"
                    BackgroundColor="{StaticResource AccentPrimary}"
                    TextColor="{StaticResource BackgroundPrimary}"
                    CornerRadius="28"
                    WidthRequest="120"
                    HeightRequest="48"
                    HorizontalOptions="End"
                    Margin="0,0,24,32" />
        </Grid>

        <!-- Edit mode: title entry + canvas + action buttons -->
        <Grid IsVisible="{Binding IsEditMode}" RowDefinitions="Auto,*,Auto">

            <!-- Title entry -->
            <Border Grid.Row="0"
                    BackgroundColor="{StaticResource BackgroundSurface}"
                    StrokeThickness="0" Padding="4,0" Margin="16,12,16,0">
                <Border.StrokeShape><RoundRectangle CornerRadius="12" /></Border.StrokeShape>
                <Entry Placeholder="Nom du croquis (optionnel)"

                       Text="{Binding Note.Title}"
                       TextColor="{StaticResource TextPrimary}"
                       PlaceholderColor="{StaticResource TextSecondary}"
                       BackgroundColor="Transparent" />
            </Border>

            <!-- Drawing area -->
            <Grid Grid.Row="1" x:Name="SketchEditorSurface">
                <Image Source="{Binding CurrentImage}"
                       Opacity="1"
                       Aspect="AspectFit"
                       IsVisible="{Binding HasBackground}" />
                <toolkit:DrawingView x:Name="DrawingCanvas"
                                     BackgroundColor="Transparent"
                                     LineColor="{Binding LineColor}"
                                     LineWidth="3"
                                     IsMultiLineModeEnabled="True" />
            </Grid>

            <!-- Buttons -->
            <VerticalStackLayout Grid.Row="2" Spacing="8" Padding="16,0,16,16">

                <!-- Couleur du trait -->
                <Label Text="Couleur du trait"
                       TextColor="{StaticResource TextSecondary}"
                       FontSize="11"
                       HorizontalOptions="Center" />
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="16">
                    <Border BackgroundColor="{StaticResource ColorWhite}" WidthRequest="32" HeightRequest="32"
                            Stroke="Transparent" StrokeThickness="3">
                        <Border.StrokeShape><Ellipse /></Border.StrokeShape>
                        <Border.Triggers>
                            <DataTrigger TargetType="Border" Binding="{Binding SelectedColorName}" Value="White">
                                <Setter Property="Stroke" Value="{StaticResource AccentPrimary}" />
                            </DataTrigger>
                        </Border.Triggers>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SetLineColorCommand}" CommandParameter="White" />
                        </Border.GestureRecognizers>
                    </Border>
                    <Border BackgroundColor="{StaticResource AccentPrimary}" WidthRequest="32" HeightRequest="32"
                            Stroke="Transparent" StrokeThickness="3">
                        <Border.StrokeShape><Ellipse /></Border.StrokeShape>
                        <Border.Triggers>
                            <DataTrigger TargetType="Border" Binding="{Binding SelectedColorName}" Value="Green">
                                <Setter Property="Stroke" Value="{StaticResource ColorWhite}" />
                            </DataTrigger>
                        </Border.Triggers>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SetLineColorCommand}" CommandParameter="Green" />
                        </Border.GestureRecognizers>
                    </Border>
                    <Border BackgroundColor="{StaticResource DangerColor}" WidthRequest="32" HeightRequest="32"
                            Stroke="Transparent" StrokeThickness="3">
                        <Border.StrokeShape><Ellipse /></Border.StrokeShape>
                        <Border.Triggers>
                            <DataTrigger TargetType="Border" Binding="{Binding SelectedColorName}" Value="Red">
                                <Setter Property="Stroke" Value="{StaticResource AccentPrimary}" />
                            </DataTrigger>
                        </Border.Triggers>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SetLineColorCommand}" CommandParameter="Red" />
                        </Border.GestureRecognizers>
                    </Border>
                </HorizontalStackLayout>

                <!-- Fond photo -->
                <Label Text="Fond photo"
                       TextColor="{StaticResource TextSecondary}"
                       FontSize="11"
                       HorizontalOptions="Center" />
                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                    <Button Grid.Column="0"
                            Text="&#xE3B0;"
                            FontFamily="MaterialSymbols"
                            Command="{Binding TakePhotoAsBackgroundCommand}"
                            BackgroundColor="{StaticResource BackgroundSurface}"
                            TextColor="{StaticResource TextPrimary}"
                            CornerRadius="12"
                            HeightRequest="40"
                            FontSize="20"
                            ToolTipProperties.Text="Prendre une photo comme fond" />
                    <Button Grid.Column="1"
                            Text="&#xE410;"
                            FontFamily="MaterialSymbols"
                            Command="{Binding PickPhotoAsBackgroundCommand}"
                            BackgroundColor="{StaticResource BackgroundSurface}"
                            TextColor="{StaticResource TextPrimary}"
                            CornerRadius="12"
                            HeightRequest="40"
                            FontSize="20"
                            ToolTipProperties.Text="Choisir une photo depuis la galerie" />
                </Grid>
                <Button Text="Tout effacer"
                        Clicked="OnClearClicked"
                        IsEnabled="{Binding CanClear}"
                        BackgroundColor="{StaticResource BackgroundSurface}"
                        TextColor="{StaticResource TextPrimary}"
                        CornerRadius="12" />
                <Button Text="Sauvegarder"
                        Clicked="OnSaveClicked"
                        BackgroundColor="{StaticResource AccentPrimary}"
                        TextColor="{StaticResource BackgroundPrimary}"
                        CornerRadius="12" />
                <Button Text="Supprimer"
                        Clicked="OnDeleteClicked"
                        IsVisible="{Binding IsNew, Converter={StaticResource InvertedBool}}"
                        BackgroundColor="Transparent"
                        TextColor="{StaticResource DangerColor}"
                        CornerRadius="12" />
            </VerticalStackLayout>

        </Grid>

    </Grid>

</ContentPage>
