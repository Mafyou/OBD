<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:OBD.Mobile.ViewModels"
             xmlns:model="clr-namespace:OBD.Mobile.Lib.Models;assembly=OBD.Mobile.Lib"
             x:Class="OBD.Mobile.Pages.Notes.NotesPage"
             x:DataType="vm:NotesViewModel"
             Title="Notes"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource BackgroundPrimary}">

    <CollectionView ItemsSource="{Binding Sectors}" Margin="0,24,0,0">
        <CollectionView.EmptyView>
            <Label Text="Aucun secteur — ajoutez-en dans les paramètres"
                   TextColor="{StaticResource TextSecondary}"
                   HorizontalOptions="Center"
                   VerticalOptions="Center" />
        </CollectionView.EmptyView>
        <CollectionView.ItemTemplate>
            <DataTemplate x:DataType="model:Sector">
                <Border Margin="16,4"
                        BackgroundColor="{StaticResource BackgroundSurface}"
                        StrokeThickness="0"
                        Padding="16,14">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12" />
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer
                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:NotesViewModel}}, Path=OpenSectorCommand}"
                            CommandParameter="{Binding .}" />
                    </Border.GestureRecognizers>
                    <Label Text="{Binding Name}"
                           FontFamily="GeistSemiBold"
                           FontSize="15"
                           TextColor="{StaticResource TextPrimary}" />
                </Border>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>

</ContentPage>
