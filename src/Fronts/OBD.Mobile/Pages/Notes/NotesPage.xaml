<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:OBD.Mobile.ViewModels"
             xmlns:model="clr-namespace:OBD.Mobile.Lib.Models;assembly=OBD.Mobile.Lib"
             x:Class="OBD.Mobile.Pages.Notes.NotesPage"
             x:DataType="vm:NotesViewModel"
             Title="Notes"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource BackgroundPrimary}">

    <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <Grid Grid.Row="0"
              BackgroundColor="{StaticResource AccentDark}"
              ColumnDefinitions="*,Auto,Auto"
              Padding="16,12,8,12">
            <Label Grid.Column="0"
                   Text="Notes"
                   FontFamily="GeistSemiBold"
                   FontSize="20"
                   TextColor="{StaticResource TextPrimary}"
                   VerticalOptions="Center" />
            <Button Grid.Column="1"
                    Text="&#xE897;"
                    FontFamily="MaterialSymbols"
                    Clicked="OnSensitiveClicked"
                    BackgroundColor="Transparent"
                    TextColor="{StaticResource TextPrimary}"
                    FontSize="22"
                    Padding="8,0"
                    HeightRequest="44" />
            <Button Grid.Column="2"
                    Text="&#xE8B6;"
                    FontFamily="MaterialSymbols"
                    Clicked="OnSearchClicked"
                    BackgroundColor="Transparent"
                    TextColor="{StaticResource TextPrimary}"
                    FontSize="22"
                    Padding="8,0"
                    HeightRequest="44" />
        </Grid>

        <CollectionView Grid.Row="1" ItemsSource="{Binding Sectors}" Margin="0,8,0,0">
            <CollectionView.EmptyView>
                <Label Text="Aucun secteur — ajoutez-en dans les paramètres"
                       TextColor="{StaticResource TextSecondary}"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="model:Sector">
                    <Border Margin="16,4"
                            BackgroundColor="{StaticResource BackgroundSurface}"
                            StrokeThickness="0"
                            Padding="16,14">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:NotesViewModel}}, Path=OpenSectorCommand}"
                                CommandParameter="{Binding .}" />
                        </Border.GestureRecognizers>
                        <Label Text="{Binding Name}"
                               FontFamily="GeistSemiBold"
                               FontSize="15"
                               TextColor="{StaticResource TextPrimary}" />
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>

</ContentPage>
