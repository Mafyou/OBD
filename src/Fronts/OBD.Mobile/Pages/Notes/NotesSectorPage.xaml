<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:OBD.Mobile.ViewModels"
             xmlns:model="clr-namespace:OBD.Mobile.Lib.Models;assembly=OBD.Mobile.Lib"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Name="ThisPage"
             x:Class="OBD.Mobile.Pages.Notes.NotesSectorPage"
             x:DataType="vm:NotesSectorViewModel"
             Title="{Binding SectorName}"
             Shell.TabBarIsVisible="False"
             BackgroundColor="{StaticResource BackgroundPrimary}">

    <Grid>
        <CollectionView ItemsSource="{Binding Notes}" Margin="0,8">
            <CollectionView.EmptyView>
                <Label Text="Aucune note — appuyez sur + pour en créer une"
                       TextColor="{StaticResource TextSecondary}"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="model:Note">
                    <Border Margin="16,4"
                            BackgroundColor="{StaticResource BackgroundSurface}"
                            StrokeThickness="0"
                            Padding="16,14">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:NotesSectorViewModel}}, Path=OpenNoteDetailCommand}"
                                CommandParameter="{Binding .}" />
                        </Border.GestureRecognizers>
                        <Border.Behaviors>
                            <toolkit:TouchBehavior
                                LongPressCompleted="OnNoteLongPressed"
                                LongPressDuration="600" />
                        </Border.Behaviors>
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{Binding DisplayText}"
                                   TextColor="{StaticResource TextPrimary}"
                                   LineBreakMode="TailTruncation"
                                   MaxLines="2" />
                            <Label Text="{Binding Keywords}"
                                   TextColor="{StaticResource TextSecondary}"
                                   FontSize="12" />
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- FABs -->
        <VerticalStackLayout HorizontalOptions="End" VerticalOptions="End"
                             Margin="0,0,20,20" Spacing="12">
            <Button Text="&#xE3C9;"
                    FontFamily="MaterialSymbols"
                    Command="{Binding OpenNewSketchCommand}"
                    BackgroundColor="{StaticResource BackgroundSurface}"
                    TextColor="{StaticResource AccentPrimary}"
                    WidthRequest="48" HeightRequest="48"
                    CornerRadius="24"
                    FontSize="22" Padding="0" />
            <Button Text="&#xE145;"
                    FontFamily="MaterialSymbols"
                    Command="{Binding OpenNewTextNoteCommand}"
                    BackgroundColor="{StaticResource AccentPrimary}"
                    TextColor="{StaticResource BackgroundPrimary}"
                    WidthRequest="56" HeightRequest="56"
                    CornerRadius="28"
                    FontSize="26" Padding="0" />
        </VerticalStackLayout>
    </Grid>

</ContentPage>
