<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- OBD Palette -->
    <Color x:Key="BackgroundPrimary">#0F1117</Color>
    <Color x:Key="BackgroundSurface">#1A1D24</Color>
    <Color x:Key="BackgroundSensitive">#0A0C10</Color>
    <Color x:Key="AccentPrimary">#10B981</Color>
    <Color x:Key="AccentDark">#065F46</Color>
    <Color x:Key="TextPrimary">#F1F5F9</Color>
    <Color x:Key="TextSecondary">#64748B</Color>
    <Color x:Key="Separator">#2A2D34</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="BackgroundPrimaryBrush" Color="{StaticResource BackgroundPrimary}" />
    <SolidColorBrush x:Key="BackgroundSurfaceBrush" Color="{StaticResource BackgroundSurface}" />
    <SolidColorBrush x:Key="BackgroundSensitiveBrush" Color="{StaticResource BackgroundSensitive}" />
    <SolidColorBrush x:Key="AccentPrimaryBrush" Color="{StaticResource AccentPrimary}" />
    <SolidColorBrush x:Key="AccentDarkBrush" Color="{StaticResource AccentDark}" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}" />
    <SolidColorBrush x:Key="SeparatorBrush" Color="{StaticResource Separator}" />

</ResourceDictionary>
